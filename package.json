{
  "name": "@theluckystrike/webext-badge",
  "version": "1.0.0",
  "description": "Typed badge text and color management for Chrome extensions — counters, status indicators, and animations. Part of @zovo/webext.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/theluckystrike/webext-badge.git"
  },
  "homepage": "https://github.com/theluckystrike/webext-badge#readme",
  "bugs": {
    "url": "https://github.com/theluckystrike/webext-badge/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepare": "pnpm run build"
  },
  "keywords": [
    "chrome-extension",
    "badge",
    "webextension",
    "typescript",
    "@zovo/webext"
  ],
  "author": "theluckystrike",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
